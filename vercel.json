{
  "redirects": [
    {
      "source": "/posts/:path*",
      "destination": "/posts/:path*",
      "permanent": false
    },
    {
      "source": "/about",
      "destination": "/about",
      "permanent": false
    },
    {
      "source": "/archive",
      "destination": "/archive",
      "permanent": false
    },
    {
      "source": "/shuoshuo",
      "destination": "/shuoshuo",
      "permanent": false
    },
    {
      "source": "/rss.xml",
      "destination": "/rss.xml",
      "permanent": false
    },
    {
      "source": "/:slug",
      "destination": "/posts/:slug",
      "permanent": true
    }
  ]
}
