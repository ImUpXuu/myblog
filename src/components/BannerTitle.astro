---
// 纯CSS实现的 Banner 打字机效果
---

<div class="banner-title-container">
    <h1 class="banner-main-title">
        <span class="typing-wrapper">
            <span class="typing-text" id="title-typing"></span><span class="cursor" id="title-cursor">|</span>
        </span>
    </h1>
    <h2 class="banner-subtitle">
        <div class="subtitle-rotator">
            <span class="subtitle-text" data-text="HI I am UpXuu">HI I am UpXuu</span>
            <span class="subtitle-text" data-text="upxu and you...">upxu and you...</span>
            <span class="subtitle-text" data-text="Life, coding...">Life, coding...</span>
        </div>
        <span class="cursor">|</span>
    </h2>
</div>

<style>
.banner-title-container {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    z-index: 10;
    width: 100%;
    padding: 0 20px;
    box-sizing: border-box;
}

body:not(.lg\:is-home) .banner-title-container {
    top: 35vh;
    transform: translate(-50%, 0);
}

@media (max-width: 768px) {
    body:not(.lg\:is-home) .banner-title-container {
        top: 45vh;
        transform: translate(-50%, 0);
    }
}

.banner-main-title {
    font-size: clamp(2rem, 6vw, 4rem);
    font-weight: 700;
    color: #ffffff;
    text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.6);
    margin: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 1.2em;
    line-height: 1.3;
}

.banner-subtitle {
    font-size: clamp(1rem, 3vw, 1.5rem);
    font-weight: 400;
    color: #ffffff;
    text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.6);
    margin-top: 0.5rem;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 1.2em;
    line-height: 1.3;
    gap: 4px;
}

.typing-wrapper {
    display: inline-block;
    position: relative;
}

.typing-text {
    display: inline;
    overflow: hidden;
    white-space: nowrap;
    border-right: 3px solid #ffffff;
    animation: typing 2s steps(13, end), blink-caret 0.75s step-end infinite;
    max-width: 0;
}

@keyframes typing {
    from { max-width: 0; }
    to { max-width: 12ch; }
}

@keyframes blink-caret {
    from, to { border-color: transparent; }
    50% { border-color: #ffffff; }
}

.cursor {
    display: inline-block;
    color: #ffffff;
    font-weight: 300;
    animation: blink 1s step-end infinite;
}

@keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
}

/* 副标题轮播 */
.subtitle-rotator {
    position: relative;
    display: inline-flex;
    overflow: hidden;
    height: 1.4em;
    width: 18ch;
}

.subtitle-text {
    position: absolute;
    white-space: nowrap;
    opacity: 0;
    transform: translateY(100%);
    animation: rotateSubtitles 9s ease-in-out infinite;
}

.subtitle-text:nth-child(1) { animation-delay: 0s; }
.subtitle-text:nth-child(2) { animation-delay: 3s; }
.subtitle-text:nth-child(3) { animation-delay: 6s; }

@keyframes rotateSubtitles {
    0% { opacity: 0; transform: translateY(100%); }
    5% { opacity: 1; transform: translateY(0); }
    30% { opacity: 1; transform: translateY(0); }
    35% { opacity: 0; transform: translateY(-100%); }
    100% { opacity: 0; transform: translateY(-100%); }
}

/* 移动端优化 */
@media (max-width: 768px) {
    .banner-title-container {
        padding: 0 15px;
        top: 45vh;
        transform: translate(-50%, 0);
    }

    .banner-main-title {
        font-size: clamp(1.8rem, 8vw, 3rem);
    }

    .banner-subtitle {
        font-size: clamp(1rem, 5vw, 1.3rem);
        margin-top: 0.8rem;
    }

    .typing-text {
        animation: typing-mobile 2s steps(13, end), blink-caret 0.75s step-end infinite;
        max-width: 0;
    }

    @keyframes typing-mobile {
        from { max-width: 0; }
        to { max-width: 12ch; }
    }
}

@media (max-width: 480px) {
    .banner-title-container {
        top: 42vh;
    }

    .banner-main-title {
        font-size: clamp(1.6rem, 9vw, 2.5rem);
    }

    .banner-subtitle {
        font-size: clamp(0.95rem, 6vw, 1.2rem);
        margin-top: 0.7rem;
    }
}

@media (max-width: 360px) {
    .banner-title-container {
        top: 40vh;
        padding: 0 12px;
    }

    .banner-main-title {
        font-size: clamp(1.5rem, 10vw, 2.2rem);
    }

    .banner-subtitle {
        font-size: clamp(0.9rem, 7vw, 1.1rem);
        margin-top: 0.6rem;
    }
}
</style>