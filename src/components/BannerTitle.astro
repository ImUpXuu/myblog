---
// 打字机效果的 Banner 标题组件
---

<div class="banner-title-container">
    <h1 class="banner-main-title">
        <span class="typing-wrapper">
            <span class="typing-text" id="title-typing"></span><span class="cursor" id="title-cursor">|</span>
        </span>
    </h1>
    <h2 class="banner-subtitle">
        <span class="typing-wrapper">
            <span class="typing-text" id="subtitle-typing"></span><span class="cursor" id="subtitle-cursor">|</span>
        </span>
    </h2>
</div>

<style>
.banner-title-container {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    z-index: 10;
    width: 100%;
    padding: 0 20px;
    box-sizing: border-box;
}

body:not(.lg\:is-home) .banner-title-container {
    top: 35vh;
    transform: translate(-50%, 0);
}

@media (max-width: 768px) {
    body:not(.lg\:is-home) .banner-title-container {
        top: 45vh;
        transform: translate(-50%, 0);
    }
}

.banner-main-title {
    font-size: clamp(2rem, 6vw, 4rem);
    font-weight: 700;
    color: #ffffff;
    text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.6);
    margin: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 1.2em;
    line-height: 1.3;
}

.banner-subtitle {
    font-size: clamp(1rem, 3vw, 1.5rem);
    font-weight: 400;
    color: #ffffff;
    text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.6);
    margin-top: 0.5rem;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 1.2em;
    line-height: 1.3;
}

.typing-wrapper {
    display: inline-block;
    position: relative;
    max-width: 100%;
}

.typing-text {
    display: inline;
    white-space: pre-wrap;
    word-break: break-word;
}

.cursor {
    display: inline-block;
    color: #ffffff;
    font-weight: 300;
    animation: blink 1s step-end infinite;
    margin-left: 2px;
}

@keyframes blink {
    0%, 100% {
        opacity: 1;
    }
    50% {
        opacity: 0;
    }
}

/* 烟花粒子效果 */
.spark {
    position: absolute;
    pointer-events: none;
    border-radius: 50%;
    animation: spark-fade 0.6s ease-out forwards;
}

@keyframes spark-fade {
    0% {
        opacity: 1;
        transform: translate(0, 0) scale(1);
    }
    100% {
        opacity: 0;
        transform: translate(var(--tx), var(--ty)) scale(0);
    }
}
</style>

<script>
let _controller = null;
let initialized = false;

// 防止重复初始化
if (window.__bannerInitialized) {
    initialized = true;
} else {
    window.__bannerInitialized = true;
}

function sleep(ms) {
    return new Promise(resolve => {
        _controller = { resolve };
        setTimeout(resolve, ms);
    });
}

// 创建烟花效果
function createSpark(x, y) {
    const colors = ['#fff', '#ffd700', '#ff6b6b', '#4ecdc4', '#ffe66d'];
    const sparkCount = 8;
    
    for (let i = 0; i < sparkCount; i++) {
        const spark = document.createElement('span');
        spark.className = 'spark';
        spark.style.left = x + 'px';
        spark.style.top = y + 'px';
        spark.style.width = (Math.random() * 4 + 2) + 'px';
        spark.style.height = spark.style.width;
        spark.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
        
        const angle = (i / sparkCount) * Math.PI * 2;
        const distance = Math.random() * 30 + 20;
        spark.style.setProperty('--tx', Math.cos(angle) * distance + 'px');
        spark.style.setProperty('--ty', Math.sin(angle) * distance + 'px');
        
        document.querySelector('.banner-title-container').appendChild(spark);
        
        setTimeout(() => spark.remove(), 600);
    }
}

async function typeWriter(element, text, speed = 100, withSpark = false) {
    element.textContent = '';
    const rect = element.getBoundingClientRect();
    const baseY = rect.top + rect.height / 2;
    
    for (let i = 0; i < text.length; i++) {
        element.textContent += text.charAt(i);
        
        if (withSpark) {
            const charX = rect.left + (i * 10);
            createSpark(charX, baseY);
        }
        
        await sleep(speed);
    }
}

async function deleteWriter(element, speed = 50) {
    while (element.textContent.length > 0) {
        element.textContent = element.textContent.slice(0, -1);
        await sleep(speed);
    }
}

const subtitles = [
    "HI I am UpXuu",
    "upxu and you...",
    "Life, coding and everything"
];

let currentSubtitleIndex = 0;

async function initAnimation() {
    if (initialized) return;
    initialized = true;

    const titleText = "UpXuu's Blog";

    const cursors = document.querySelectorAll('.cursor');
    cursors.forEach(cursor => cursor.style.opacity = '0');

    const titleElement = document.getElementById('title-typing');
    const subtitleElement = document.getElementById('subtitle-typing');
    if (!titleElement || !subtitleElement) return;

    titleElement.textContent = '';
    subtitleElement.textContent = '';

    const titleCursor = document.getElementById('title-cursor');
    const subtitleCursor = document.getElementById('subtitle-cursor');
    if (titleCursor) titleCursor.style.opacity = '1';
    if (subtitleCursor) subtitleCursor.style.opacity = '1';

    // 同时开始主标题和副标题的打字效果
    await Promise.all([
        typeWriter(titleElement, titleText, 150, true),
        typeWriter(subtitleElement, subtitles[0], 150, true)
    ]);
    
    await sleep(2000);
    
    // 开始副标题轮播
    currentSubtitleIndex = 1;
    while (true) {
        const currentText = subtitles[currentSubtitleIndex];
        await deleteWriter(subtitleElement, 50);
        await sleep(300);
        await typeWriter(subtitleElement, currentText, 100, true);
        await sleep(2000);
        currentSubtitleIndex = (currentSubtitleIndex + 1) % subtitles.length;
    }
}

// 只在首次加载时执行
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAnimation, { once: true });
} else {
    initAnimation();
}
</script>
