---
// 打字机效果的 Banner 标题组件
---

<div class="banner-title-container">
    <h1 class="banner-main-title">
        <span class="typing-wrapper">
            <span class="typing-text" id="title-typing"></span><span class="cursor" id="title-cursor">|</span>
        </span>
    </h1>
    <h2 class="banner-subtitle">
        <span class="typing-wrapper">
            <span class="typing-text" id="subtitle-typing"></span><span class="cursor" id="subtitle-cursor">|</span>
        </span>
    </h2>
</div>

<style>
.banner-title-container {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    z-index: 10;
    width: 100%;
    padding: 0 20px;
    box-sizing: border-box;
}

body:not(.lg\:is-home) .banner-title-container {
    top: 35vh;
    transform: translate(-50%, 0);
}

@media (max-width: 768px) {
    body:not(.lg\:is-home) .banner-title-container {
        top: 45vh;
        transform: translate(-50%, 0);
    }
}

.banner-main-title {
    font-size: clamp(2rem, 6vw, 4rem);
    font-weight: 700;
    color: #ffffff;
    text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.6);
    margin: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 1.2em;
    line-height: 1.3;
}

.banner-subtitle {
    font-size: clamp(1rem, 3vw, 1.5rem);
    font-weight: 400;
    color: #ffffff;
    text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.6);
    margin-top: 0.5rem;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 1.2em;
    line-height: 1.3;
}

.typing-wrapper {
    display: inline-block;
    position: relative;
    max-width: 100%;
}

.typing-text {
    display: inline;
    white-space: pre-wrap;
    word-break: break-word;
}

.cursor {
    display: inline-block;
    color: #ffffff;
    font-weight: 300;
    animation: blink 1s step-end infinite;
    margin-left: 2px;
}

@keyframes blink {
    0%, 100% {
        opacity: 1;
    }
    50% {
        opacity: 0;
    }
}

/* 移动端优化 - 使用 vh 单位确保在可视区域内 */
@media (max-width: 768px) {
    .banner-title-container {
        padding: 0 15px;
        top: 45vh;
        transform: translate(-50%, 0);
    }
    
    .banner-main-title {
        font-size: clamp(1.8rem, 8vw, 3rem);
    }
    
    .banner-subtitle {
        font-size: clamp(1rem, 5vw, 1.3rem);
        margin-top: 0.8rem;
    }
}

/* 小屏幕进一步优化 */
@media (max-width: 480px) {
    .banner-title-container {
        top: 42vh;
    }
    
    .banner-main-title {
        font-size: clamp(1.6rem, 9vw, 2.5rem);
    }
    
    .banner-subtitle {
        font-size: clamp(0.95rem, 6vw, 1.2rem);
        margin-top: 0.7rem;
    }
}

/* 超小屏幕 */
@media (max-width: 360px) {
    .banner-title-container {
        top: 40vh;
        padding: 0 12px;
    }
    
    .banner-main-title {
        font-size: clamp(1.5rem, 10vw, 2.2rem);
    }
    
    .banner-subtitle {
        font-size: clamp(0.9rem, 7vw, 1.1rem);
        margin-top: 0.6rem;
    }
}
</style>

<script>
let currentTimeouts = [];
let shouldStop = false;

function clearAll() {
    currentTimeouts.forEach(t => clearTimeout(t));
    currentTimeouts = [];
}

function addTimeout(fn, delay) {
    const id = setTimeout(fn, delay);
    currentTimeouts.push(id);
    return id;
}

function sleep(ms) {
    return new Promise(resolve => {
        const id = setTimeout(resolve, ms);
        currentTimeouts.push(id);
    });
}

async function typeWriter(element, text, speed) {
    element.textContent = '';
    for (let i = 0; i < text.length; i++) {
        if (shouldStop) return;
        element.textContent += text.slice(0, i + 1);
        await sleep(speed);
    }
}

async function deleteText(element, speed) {
    while (element.textContent.length > 0) {
        if (shouldStop) return;
        element.textContent = element.textContent.slice(0, -1);
        await sleep(speed);
    }
}

const subtitles = ["HI I am UpXuu", "upxu and you...", "Life, coding and everything"];
let subtitleIndex = 0;

async function runAnimation() {
    const titleEl = document.getElementById('title-typing');
    const subtitleEl = document.getElementById('subtitle-typing');
    const titleCursor = document.getElementById('title-cursor');
    const subtitleCursor = document.getElementById('subtitle-cursor');

    if (!titleEl || !subtitleEl) return;

    document.querySelectorAll('.cursor').forEach(c => c.style.opacity = '0');
    titleEl.textContent = '';
    subtitleEl.textContent = '';

    titleCursor.style.opacity = '1';
    await typeWriter(titleEl, "UpXuu's Blog", 150);

    if (shouldStop) return;
    await sleep(500);

    subtitleCursor.style.opacity = '1';

    while (!shouldStop) {
        const text = subtitles[subtitleIndex];
        await typeWriter(subtitleEl, text, 100);
        if (shouldStop) return;

        await sleep(2000);
        if (shouldStop) return;

        await deleteText(subtitleEl, 50);
        if (shouldStop) return;

        await sleep(300);
        subtitleIndex = (subtitleIndex + 1) % subtitles.length;
    }
}

function startAnimation() {
    shouldStop = false;
    clearAll();
    runAnimation();
}

function stopAnimation() {
    shouldStop = true;
    clearAll();
}

if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', startAnimation);
} else {
    startAnimation();
}

if (window.swup) {
    window.swup.hooks.on('page:view', () => {
        stopAnimation();
        addTimeout(startAnimation, 300);
    });
}
</script>
