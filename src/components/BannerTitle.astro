---
---

<div class="banner-title-container">
    <h1 class="banner-main-title">
        <span class="typing-text">UpXuu's Blog</span><span class="cursor">|</span>
    </h1>
    <h2 class="banner-subtitle">
        <div class="subtitle-rotator">
            <span class="subtitle-item">HI I am UpXuu</span>
            <span class="subtitle-item">upxu and you...</span>
            <span class="subtitle-item">Life, coding...</span>
        </div>
        <span class="cursor">|</span>
    </h2>
</div>

<style>
.banner-title-container {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    z-index: 10;
    width: 100%;
    padding: 0 20px;
    box-sizing: border-box;
}

body:not(.lg\:is-home) .banner-title-container {
    top: 35vh;
    transform: translate(-50%, 0);
}

@media (max-width: 768px) {
    body:not(.lg\:is-home) .banner-title-container {
        top: 45vh;
        transform: translate(-50%, 0);
    }
}

.banner-main-title {
    font-size: clamp(2rem, 6vw, 4rem);
    font-weight: 700;
    color: #ffffff;
    text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.6);
    margin: 0;
    display: inline-block;
}

.banner-subtitle {
    font-size: clamp(1rem, 3vw, 1.5rem);
    font-weight: 400;
    color: #ffffff;
    text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.6);
    margin-top: 0.5rem;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 4px;
}

/* 打字机效果 */
.typing-text {
    display: inline-block;
    overflow: hidden;
    border-right: 3px solid #ffffff;
    white-space: nowrap;
    margin: 0;
    animation: typing 2.5s steps(14, end) forwards, blink 0.75s step-end infinite;
    max-width: 0;
}

@keyframes typing {
    from { max-width: 0; }
    to { max-width: 14ch; }
}

@keyframes blink {
    from, to { border-color: transparent; }
    50% { border-color: #ffffff; }
}

/* 副标题轮播 */
.subtitle-rotator {
    display: inline-block;
    position: relative;
    height: 1.4em;
    overflow: hidden;
    width: 18ch;
}

.subtitle-item {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
    opacity: 0;
    animation: subtitleCycle 9s infinite;
}

.subtitle-item:nth-child(1) {
    animation-delay: 0s;
}

.subtitle-item:nth-child(2) {
    animation-delay: 3s;
}

.subtitle-item:nth-child(3) {
    animation-delay: 6s;
}

@keyframes subtitleCycle {
    0%, 5% {
        opacity: 0;
        transform: translateX(-50%) translateY(100%);
    }
    10%, 30% {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
    }
    35%, 40% {
        opacity: 0;
        transform: translateX(-50%) translateY(-100%);
    }
    100% {
        opacity: 0;
        transform: translateX(-50%) translateY(-100%);
    }
}

/* 光标闪烁 */
.cursor {
    display: inline-block;
    color: #ffffff;
    animation: cursorBlink 1s step-end infinite;
}

@keyframes cursorBlink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
}

/* 移动端优化 */
@media (max-width: 768px) {
    .banner-title-container {
        top: 45vh;
    }

    .banner-main-title {
        font-size: clamp(1.8rem, 8vw, 3rem);
    }

    .typing-text {
        animation: typing-mobile 2.5s steps(14, end) forwards, blink 0.75s step-end infinite;
    }

    @keyframes typing-mobile {
        from { max-width: 0; }
        to { max-width: 14ch; }
    }
}

@media (max-width: 480px) {
    .banner-title-container {
        top: 42vh;
    }

    .banner-main-title {
        font-size: clamp(1.6rem, 9vw, 2.5rem);
    }

    .banner-subtitle {
        font-size: clamp(0.95rem, 6vw, 1.2rem);
    }
}

@media (max-width: 360px) {
    .banner-title-container {
        top: 40vh;
        padding: 0 12px;
    }

    .banner-main-title {
        font-size: clamp(1.5rem, 10vw, 2.2rem);
    }

    .banner-subtitle {
        font-size: clamp(0.9rem, 7vw, 1.1rem);
    }
}
</style>