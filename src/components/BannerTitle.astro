---
// 打字机效果的 Banner 标题组件
---

<div class="banner-title-container">
    <h1 class="banner-main-title">
        <span class="typing-text" data-text="UpXuu's Blog"></span>
    </h1>
    <h2 class="banner-subtitle">
        <span class="typing-text" data-text="Life, Study and... upxu and you"></span>
    </h2>
</div>

<style>
.banner-title-container {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    z-index: 10;
    width: 100%;
    padding: 0 20px;
    box-sizing: border-box;
}

.banner-main-title {
    font-size: clamp(2rem, 6vw, 4rem);
    font-weight: 700;
    color: #ffffff;
    text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.6);
    margin: 0;
    display: inline-block;
}

.banner-subtitle {
    font-size: clamp(1rem, 3vw, 1.5rem);
    font-weight: 400;
    color: #ffffff;
    text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.6);
    margin-top: 0.5rem;
    display: inline-block;
}

.typing-text {
    display: inline-block;
    position: relative;
}

.typing-text::after {
    content: '|';
    position: absolute;
    right: -8px;
    color: #ffffff;
    animation: blink 1s step-end infinite;
}

.typing-text.typing-complete::after {
    animation: none;
    opacity: 0;
}

@keyframes blink {
    0%, 100% {
        opacity: 1;
    }
    50% {
        opacity: 0;
    }
}

/* 移动端优化 */
@media (max-width: 768px) {
    .banner-title-container {
        top: 45%;
        padding: 0 15px;
    }
    
    .banner-main-title {
        font-size: clamp(1.5rem, 8vw, 2.5rem);
    }
    
    .banner-subtitle {
        font-size: clamp(0.9rem, 4vw, 1.2rem);
        margin-top: 0.3rem;
    }
}

@media (max-width: 480px) {
    .banner-title-container {
        top: 40%;
    }
}
</style>

<script>
// 打字机效果
function typeWriter(element, text, speed = 100, callback?) {
    let i = 0;
    element.textContent = '';
    
    const type = () => {
        if (i < text.length) {
            element.textContent += text.charAt(i);
            i++;
            setTimeout(type, speed);
        } else if (callback) {
            callback();
        }
    };
    
    type();
}

// 初始化
function init() {
    const elements = document.querySelectorAll('.typing-text');
    if (elements.length < 2) return;
    
    const titleEl = elements[0];
    const subtitleEl = elements[1];
    const titleText = titleEl.getAttribute('data-text') || '';
    const subtitleText = subtitleEl.getAttribute('data-text') || '';
    
    // 标题动画
    setTimeout(() => {
        typeWriter(titleEl, titleText, 150, () => {
            titleEl.classList.add('typing-complete');
            
            // 副标题动画
            setTimeout(() => {
                typeWriter(subtitleEl, subtitleText, 150, () => {
                    subtitleEl.classList.add('typing-complete');
                });
            }, 500);
        });
    }, 500);
}

// DOM 加载完成
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
} else {
    init();
}

// Swup 支持
if (window.swup) {
    window.swup.hooks.on('page:view', () => {
        init();
    });
}
</script>
