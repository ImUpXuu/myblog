---
// 打字机效果的 Banner 标题组件
---

<div class="banner-title-container">
    <h1 class="banner-main-title">
        <span class="typing-wrapper">
            <span class="typing-text" id="title-typing"></span><span class="cursor" id="title-cursor">|</span>
        </span>
    </h1>
    <h2 class="banner-subtitle">
        <span class="typing-wrapper">
            <span class="typing-text" id="subtitle-typing"></span><span class="cursor" id="subtitle-cursor">|</span>
        </span>
    </h2>
</div>

<style>
.banner-title-container {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    z-index: 10;
    width: 100%;
    padding: 0 20px;
    box-sizing: border-box;
}

.banner-main-title {
    font-size: clamp(2rem, 6vw, 4rem);
    font-weight: 700;
    color: #ffffff;
    text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.6);
    margin: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 1.2em;
    line-height: 1.3;
}

.banner-subtitle {
    font-size: clamp(1rem, 3vw, 1.5rem);
    font-weight: 400;
    color: #ffffff;
    text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.6);
    margin-top: 0.5rem;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 1.2em;
    line-height: 1.3;
}

.typing-wrapper {
    display: inline-block;
    position: relative;
    max-width: 100%;
}

.typing-text {
    display: inline;
    word-break: break-word;
}

.cursor {
    display: inline-block;
    color: #ffffff;
    font-weight: 300;
    animation: blink 1s step-end infinite;
    margin-left: 2px;
}

@keyframes blink {
    0%, 100% {
        opacity: 1;
    }
    50% {
        opacity: 0;
    }
}

/* 移动端优化 - 使用 vh 单位确保在可视区域内 */
@media (max-width: 768px) {
    .banner-title-container {
        padding: 0 15px;
        top: 40vh;
        transform: translate(-50%, 0);
    }
    
    .banner-main-title {
        font-size: clamp(1.5rem, 7vw, 2.5rem);
    }
    
    .banner-subtitle {
        font-size: clamp(0.9rem, 4vw, 1.1rem);
        margin-top: 0.5rem;
    }
}

/* 小屏幕进一步优化 */
@media (max-width: 480px) {
    .banner-title-container {
        top: 35vh;
    }
    
    .banner-main-title {
        font-size: clamp(1.3rem, 8vw, 2rem);
    }
    
    .banner-subtitle {
        font-size: clamp(0.8rem, 5vw, 1rem);
    }
}

/* 超小屏幕 */
@media (max-width: 360px) {
    .banner-title-container {
        top: 30vh;
        padding: 0 10px;
    }
    
    .banner-main-title {
        font-size: clamp(1.2rem, 9vw, 1.8rem);
    }
    
    .banner-subtitle {
        font-size: clamp(0.75rem, 5vw, 0.9rem);
    }
}
</style>

<script>
// 打字机效果函数
function typeWriter(elementId, cursorId, text, speed = 100, callback?) {
    const element = document.getElementById(elementId);
    const cursor = document.getElementById(cursorId);
    
    if (!element || !cursor) return;
    
    element.textContent = '';
    let i = 0;
    
    const type = () => {
        if (i < text.length) {
            element.textContent += text.charAt(i);
            i++;
            setTimeout(type, speed);
        } else if (callback) {
            callback();
        }
    };
    
    type();
}

// 初始化动画
function initAnimation() {
    const titleText = "UpXuu's Blog";
    const subtitleText = "Life, Study and... upxu and you";
    
    // 先隐藏光标
    const cursors = document.querySelectorAll('.cursor');
    cursors.forEach(cursor => {
        cursor.style.opacity = '0';
    });
    
    // 延迟后开始标题动画
    setTimeout(() => {
        // 显示标题光标
        const titleCursor = document.getElementById('title-cursor');
        if (titleCursor) {
            titleCursor.style.opacity = '1';
        }
        
        typeWriter('title-typing', 'title-cursor', titleText, 150, () => {
            // 标题完成后，延迟开始副标题
            setTimeout(() => {
                // 显示副标题光标
                const subtitleCursor = document.getElementById('subtitle-cursor');
                if (subtitleCursor) {
                    subtitleCursor.style.opacity = '1';
                }
                
                typeWriter('subtitle-typing', 'subtitle-cursor', subtitleText, 150);
            }, 500);
        });
    }, 500);
}

// 页面加载时执行
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAnimation);
} else {
    initAnimation();
}

// Swup 页面切换后重新执行动画
if (window.swup) {
    window.swup.hooks.on('page:view', () => {
        initAnimation();
    });
}
</script>
