---
import MainGridLayout from "../layouts/MainGridLayout.astro";
import BannerTitle from "../components/BannerTitle.astro";
import { profileConfig, siteConfig } from "../config";

const galleryIndexUrl = "https://edit.upxuu.com/img/index.json";

// 使用 wsrv.nl 代理加速图片加载
function getProxyUrl(url: string, width = 400, height = 400): string {
	if (!url) return url;
	return `https://wsrv.nl/?url=${encodeURIComponent(url)}&w=${width}&h=${height}&fit=cover&q=85`;
}

let galleryData = null;
let error = null;

try {
	const response = await fetch(galleryIndexUrl);
	if (response.ok) {
		galleryData = await response.json();
	} else {
		error = "无法加载图库索引";
	}
} catch (e) {
	error = "加载图库索引失败";
	console.error(e);
}

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "ImageGallery",
	"@id": `${Astro.site}gallery`,
	name: "图库",
	description: "UpXuu 的图片库",
	url: `${Astro.site}gallery`,
	author: {
		"@type": "Person",
		name: profileConfig.name,
	},
	inLanguage: siteConfig.lang.replace("_", "-"),
};
---

<MainGridLayout title="图库" description="UpXuu 的图片库">
	<BannerTitle slot="banner-title"></BannerTitle>
	<script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
	
	<div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
		<div class="card-base z-10 px-6 md:px-9 py-6 relative w-full">
			{error ? (
				<div class="text-center py-12">
					<div class="text-6xl mb-4">😕</div>
					<p class="text-red-500 text-lg">{error}</p>
					<p class="text-gray-500 dark:text-gray-400 mt-2 text-sm">请检查网络连接或稍后重试</p>
				</div>
			) : !galleryData ? (
				<div class="text-center py-12">
					<div class="animate-pulse space-y-4">
						<div class="h-4 bg-gray-200 dark:bg-gray-700 rounded w-3/4 mx-auto"></div>
						<div class="h-4 bg-gray-200 dark:bg-gray-700 rounded w-1/2 mx-auto"></div>
						<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-8">
							{Array.from({ length: 6 }).map((_, i) => (
								<div class="aspect-video bg-gray-200 dark:bg-gray-700 rounded-lg"></div>
							))}
						</div>
					</div>
				</div>
			) : (
				<div class="gallery-container">
					<!-- 月份列表 -->
					{galleryData.months?.length > 0 ? (
						<>
							<div class="months-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
								{galleryData.months.map((month, index) => (
									<a 
										href={`/gallery/${month.ym.replace('-', '/')}`}
										class="month-card block group"
										style={`animation-delay: ${index * 50}ms`}
									>
										<div class="card-base overflow-hidden transition-all duration-300 group-hover:scale-[1.02] group-hover:shadow-xl">
											{month.preview ? (
												<div class="preview-container relative aspect-video overflow-hidden">
													<img 
														src={getProxyUrl(month.preview, 640, 360)} 
														alt={`${month.ym} 预览，共 ${month.count} 张图片`}
														class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-110"
														loading="lazy"
													/>
													<div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
													<div class="absolute bottom-0 left-0 right-0 p-4 text-white">
														<div class="font-bold text-xl mb-1">{month.ym}</div>
														<div class="text-sm opacity-90 flex items-center gap-2">
															<span>📷 {month.count} 张图片</span>
														</div>
													</div>
												</div>
											) : (
												<div class="preview-container aspect-video bg-gradient-to-br from-indigo-100 to-purple-100 dark:from-gray-700 dark:to-gray-800 flex items-center justify-center">
													<div class="text-center">
														<div class="text-5xl mb-3">📷</div>
														<div class="font-bold text-lg text-gray-700 dark:text-gray-300">{month.ym}</div>
														<div class="text-sm text-gray-500 dark:text-gray-400 mt-1">{month.count} 张图片</div>
													</div>
												</div>
											)}
										</div>
									</a>
								))}
							</div>
							
							<!-- 统计信息 -->
							<div class="mt-10 pt-6 border-t border-gray-200 dark:border-gray-700">
								<div class="flex flex-wrap items-center justify-between gap-4 text-sm text-gray-600 dark:text-gray-400">
									<div class="flex items-center gap-4">
										<span class="flex items-center gap-2">
											<span class="text-lg">📊</span>
											<span>共 <strong class="text-primary">{galleryData.months.length}</strong> 个月份</span>
										</span>
										<span>•</span>
										<span class="flex items-center gap-2">
											<span class="text-lg">🖼️</span>
											<span>总计 <strong class="text-primary">{galleryData.months.reduce((sum, m) => sum + m.count, 0)}</strong> 张图片</span>
										</span>
									</div>
									<span class="text-xs opacity-75">
										最后更新：{new Date(galleryData.updated).toLocaleString('zh-CN', { 
											year: 'numeric', 
											month: '2-digit', 
											day: '2-digit',
											hour: '2-digit',
											minute: '2-digit'
										})}
									</span>
								</div>
							</div>
						</>
					) : (
						<div class="text-center py-16">
							<div class="text-7xl mb-6">📸</div>
							<h3 class="text-xl font-bold text-gray-700 dark:text-gray-300 mb-2">还没有图片</h3>
							<p class="text-gray-500 dark:text-gray-400">图片正在上传中，稍后再来看看吧</p>
						</div>
					)}
				</div>
			)}
		</div>
	</div>
</MainGridLayout>

<style>
.gallery-container {
	animation: fadeIn 0.6s ease-out;
}

.month-card {
	text-decoration: none;
	color: inherit;
}

.month-card .month-card {
	animation: slideUp 0.6s ease-out backwards;
}

@keyframes fadeIn {
	from {
		opacity: 0;
		transform: translateY(20px);
	}
	to {
		opacity: 1;
		transform: translateY(0);
	}
}

@keyframes slideUp {
	from {
		opacity: 0;
		transform: translateY(30px);
	}
	to {
		opacity: 1;
		transform: translateY(0);
	}
}
</style>
