---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import BannerTitle from "@/components/BannerTitle.astro";
import { profileConfig, siteConfig } from "@/config";

export async function getStaticPaths() {
	// 获取图库索引
	const galleryIndexUrl = "https://edit.upxuu.com/img/index.json";
	let months = [];
	
	try {
		const response = await fetch(galleryIndexUrl);
		if (response.ok) {
			const data = await response.json();
			months = data.months || [];
		}
	} catch (e) {
		console.error("Failed to fetch gallery index:", e);
	}
	
	return months.map((month) => ({
		params: { year: month.ym.split('-')[0], month: month.ym.split('-')[1] },
		props: { monthData: month },
	}));
}

const { monthData } = Astro.props;
const { year, month } = Astro.params;

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "ImageGallery",
	"@id": `${Astro.site}gallery/${year}/${month}`,
	name: `${year}年${month}月图库`,
	description: `${year}年${month}月的图片集`,
	url: `${Astro.site}gallery/${year}/${month}`,
	author: {
		"@type": "Person",
		name: profileConfig.name,
	},
	inLanguage: siteConfig.lang.replace("_", "-"),
};
---

<MainGridLayout 
	title={`${year}年${month}月`} 
	description={`${year}年${month}月的图片集`}
>
	<BannerTitle slot="banner-title"></BannerTitle>
	<script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
	
	<div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
		<div class="card-base z-10 px-6 md:px-9 py-6 relative w-full">
			<!-- 返回链接 -->
			<div class="mb-6">
				<a href="/gallery" class="inline-flex items-center text-primary hover:underline">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" viewBox="0 0 20 20" fill="currentColor">
						<path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
					</svg>
					返回图库
				</a>
			</div>
			
			<!-- 图片网格 -->
			<div id="month-gallery" class="image-grid">
				<!-- 图片将通过 JavaScript 加载 -->
			</div>
		</div>
	</div>
</MainGridLayout>

<script>
// 加载月份图片
async function loadMonthImages() {
	const year = "{year}";
	const month = "{month}";
	const monthIndexUrl = `https://edit.upxuu.com/img/${year}/${month}/index.json`;
	
	// 修复 URL，确保使用 HTTPS 并处理相对路径
	function fixUrl(url) {
		if (!url) return url;
		// 如果是相对路径，转换为完整 URL
		if (url.startsWith('images/')) {
			return url.replace('images/', 'https://edit.upxuu.com/img/');
		}
		// 将 http:// 替换为 https://
		return url.replace('http://', 'https://');
	}
	
	try {
		const response = await fetch(monthIndexUrl);
		if (!response.ok) {
			throw new Error('Failed to load month images');
		}
		
		const data = await response.json();
		const galleryContainer = document.getElementById('month-gallery');
		
		if (!data.images || data.images.length === 0) {
			galleryContainer.innerHTML = `
				<div class="text-center py-12">
					<div class="text-6xl mb-4">📸</div>
					<p class="text-gray-500 dark:text-gray-400">这个月份还没有图片</p>
				</div>
			`;
			return;
		}
		
		// 修复所有图片 URL 为 HTTPS
		data.images.forEach(image => {
			if (image.url) image.url = fixUrl(image.url);
		});
		
		// 创建图片网格
		const gridHtml = data.images.map((image, index) => `
			<div class="image-item group" style="animation-delay: ${index * 50}ms">
				<div class="image-wrapper">
					<img 
						src="${image.url}" 
						alt="${image.name}"
						class="gallery-image"
						loading="lazy"
						data-pswp-src="${image.url}"
						data-pswp-width="${image.width || 1920}"
						data-pswp-height="${image.height || 1080}"
					/>
					<div class="image-overlay">
						<div class="image-info">
							<div class="image-name">${image.name}</div>
							<div class="image-meta">
								${image.size ? formatFileSize(image.size) : ''}
								${image.date ? ' • ' + new Date(image.date).toLocaleDateString('zh-CN') : ''}
							</div>
						</div>
					</div>
				</div>
			</div>
		`).join('');
		
		galleryContainer.innerHTML = `
			<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
				${gridHtml}
			</div>
			<div class="mt-6 pt-6 border-t border-gray-200 dark:border-gray-700">
				<div class="flex flex-wrap gap-4 text-sm text-gray-600 dark:text-gray-400">
					<span>共 ${data.count} 张图片</span>
					<span>•</span>
					<span>${year}年${month}月</span>
				</div>
			</div>
		`;
		
		// 初始化 PhotoSwipe
		initPhotoSwipe();
	} catch (error) {
		console.error('Error loading month images:', error);
		const galleryContainer = document.getElementById('month-gallery');
		galleryContainer.innerHTML = `
			<div class="text-center py-12">
				<p class="text-red-500">加载图片失败</p>
			</div>
		`;
	}
}

function formatFileSize(bytes) {
	if (!bytes) return '';
	const kb = bytes / 1024;
	if (kb < 1024) return kb.toFixed(1) + ' KB';
	return (kb / 1024).toFixed(1) + ' MB';
}

function initPhotoSwipe() {
	// PhotoSwipe 已经在 Layout.astro 中初始化
	// 这里只需要确保新加载的图片可以被 PhotoSwipe 识别
	if (window.lightbox) {
		window.lightbox.destroy();
		window.lightbox.init();
	}
}

// 页面加载时获取图片
if (document.readyState === 'loading') {
	document.addEventListener('DOMContentLoaded', loadMonthImages);
} else {
	loadMonthImages();
}
</script>

<style>
.image-grid {
	animation: fadeIn 0.5s ease-in;
}

.image-item {
	animation: slideUp 0.5s ease-out backwards;
}

.image-wrapper {
	position: relative;
	aspect-ratio: 4/3;
	overflow: hidden;
	border-radius: var(--radius-medium);
	cursor: pointer;
}

.gallery-image {
	width: 100%;
	height: 100%;
	object-fit: cover;
	transition: transform 0.3s ease;
}

.image-wrapper:hover .gallery-image {
	transform: scale(1.1);
}

.image-overlay {
	position: absolute;
	inset: 0;
	background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 50%);
	opacity: 0;
	transition: opacity 0.3s ease;
	display: flex;
	align-items: flex-end;
	padding: 1rem;
}

.image-wrapper:hover .image-overlay {
	opacity: 1;
}

.image-info {
	color: white;
	transform: translateY(10px);
	transition: transform 0.3s ease;
}

.image-wrapper:hover .image-info {
	transform: translateY(0);
}

.image-name {
	font-weight: 600;
	font-size: 0.875rem;
	margin-bottom: 0.25rem;
	overflow: hidden;
	text-overflow: ellipsis;
	white-space: nowrap;
}

.image-meta {
	font-size: 0.75rem;
	opacity: 0.9;
}

@keyframes fadeIn {
	from {
		opacity: 0;
	}
	to {
		opacity: 1;
	}
}

@keyframes slideUp {
	from {
		opacity: 0;
		transform: translateY(20px);
	}
	to {
		opacity: 1;
		transform: translateY(0);
	}
}
</style>
