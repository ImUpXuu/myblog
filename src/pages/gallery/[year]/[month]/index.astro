---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import BannerTitle from "@/components/BannerTitle.astro";
import { profileConfig, siteConfig } from "@/config";

export async function getStaticPaths() {
	const galleryIndexUrl = "https://edit.upxuu.com/img/index.json";
	let months = [];
	
	try {
		const response = await fetch(galleryIndexUrl);
		if (response.ok) {
			const data = await response.json();
			months = data.months || [];
		}
	} catch (e) {
		console.error("Failed to fetch gallery index:", e);
	}
	
	return months.map((month) => ({
		params: { year: month.ym.split('-')[0], month: month.ym.split('-')[1] },
		props: { monthData: month },
	}));
}

const { monthData } = Astro.props;
const { year, month } = Astro.params;

// 获取月份图片数据
const monthIndexUrl = `https://edit.upxuu.com/img/${year}/${month}/index.json`;
let monthImages = [];
let error = null;

try {
	const response = await fetch(monthIndexUrl);
	if (response.ok) {
		const data = await response.json();
		monthImages = data.images || [];
	} else {
		error = "加载图片失败";
	}
} catch (e) {
	error = "加载图片失败";
	console.error(e);
}

// 使用 wsrv.nl 代理加速
function getProxyUrl(url, width = 800, height = 600) {
	if (!url) return url;
	if (url.startsWith('images/')) {
		url = url.replace('images/', 'https://edit.upxuu.com/img/');
	}
	url = url.replace('http://', 'https://');
	return `https://wsrv.nl/?url=${encodeURIComponent(url)}&w=${width}&h=${height}&fit=cover&q=85`;
}

function formatFileSize(bytes) {
	if (!bytes) return '';
	const kb = bytes / 1024;
	if (kb < 1024) return kb.toFixed(1) + ' KB';
	return (kb / 1024).toFixed(1) + ' MB';
}

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "ImageGallery",
	"@id": `${Astro.site}gallery/${year}/${month}`,
	name: `${year}年${month}月图库`,
	description: `${year}年${month}月的图片集`,
	url: `${Astro.site}gallery/${year}/${month}`,
	author: {
		"@type": "Person",
		name: profileConfig.name,
	},
	inLanguage: siteConfig.lang.replace("_", "-"),
};
---

<MainGridLayout 
	title={`${year}年${month}月`} 
	description={`${year}年${month}月的图片集`}
>
	<BannerTitle slot="banner-title"></BannerTitle>
	<script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
	
	<div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
		<div class="card-base z-10 px-6 md:px-9 py-6 relative w-full">
			<!-- 返回链接 -->
			<div class="mb-8">
				<a 
					href="/gallery" 
					class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors text-gray-700 dark:text-gray-300"
				>
					<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
						<path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
					</svg>
					返回图库
				</a>
			</div>
			
			<!-- 月份标题 -->
			<div class="mb-8 pb-6 border-b border-gray-200 dark:border-gray-700">
				<h2 class="text-3xl font-bold text-gray-800 dark:text-gray-200 mb-2">
					{year}年{month}月
				</h2>
				<p class="text-gray-600 dark:text-gray-400">
					记录美好时光
				</p>
			</div>
			
			<!-- 图片网格 - 直接服务端渲染 -->
			{error ? (
				<div class="text-center py-20">
					<div class="text-6xl mb-4">😕</div>
					<p class="text-red-500 text-lg mb-2">{error}</p>
					<p class="text-gray-500 dark:text-gray-400 text-sm">请检查网络连接或稍后重试</p>
				</div>
			) : monthImages.length > 0 ? (
				<>
					<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
						{monthImages.map((image, index) => (
							<div 
								class="image-item group" 
								style={`animation-delay: ${index * 50}ms`}
							>
								<div class="image-wrapper">
									<img 
										src={getProxyUrl(image.url, 600, 450)} 
										alt={image.name}
										class="gallery-image"
										loading="lazy"
										data-pswp-src={image.url.replace('images/', 'https://edit.upxuu.com/img/').replace('http://', 'https://')}
										data-pswp-width={image.width || 1920}
										data-pswp-height={image.height || 1080}
									/>
									<div class="image-overlay">
										<div class="image-info">
											<div class="image-name">{image.name}</div>
											<div class="image-meta">
												{image.size ? formatFileSize(image.size) : ''}
												{image.date ? ' • ' + new Date(image.date).toLocaleDateString('zh-CN') : ''}
											</div>
										</div>
									</div>
								</div>
							</div>
						))}
					</div>
					
					<!-- 统计信息 -->
					<div class="mt-10 pt-6 border-t border-gray-200 dark:border-gray-700">
						<div class="flex flex-wrap items-center justify-between gap-4 text-sm text-gray-600 dark:text-gray-400">
							<div class="flex items-center gap-4">
								<span>📷 共 <strong class="text-primary">{monthImages.length}</strong> 张图片</span>
								<span>•</span>
								<span>{year}年{month}月</span>
							</div>
						</div>
					</div>
				</>
			) : (
				<div class="text-center py-20">
					<div class="text-7xl mb-6">�</div>
					<p class="text-xl text-gray-600 dark:text-gray-400">这个月份还没有图片</p>
				</div>
			)}
		</div>
	</div>
</MainGridLayout>

<style>
.image-grid {
	animation: fadeIn 0.6s ease-out;
}

.image-item {
	animation: slideUp 0.6s ease-out backwards;
}

.image-wrapper {
	position: relative;
	aspect-ratio: 4/3;
	overflow: hidden;
	border-radius: var(--radius-medium);
	cursor: pointer;
	box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
	transition: all 0.3s ease;
}

.image-wrapper:hover {
	box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
	transform: translateY(-4px);
}

.gallery-image {
	width: 100%;
	height: 100%;
	object-fit: cover;
	transition: transform 0.5s ease;
}

.image-wrapper:hover .gallery-image {
	transform: scale(1.1);
}

.image-overlay {
	position: absolute;
	inset: 0;
	background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.4) 50%, transparent 100%);
	opacity: 0;
	transition: opacity 0.3s ease;
	display: flex;
	align-items: flex-end;
	padding: 1rem;
}

.image-wrapper:hover .image-overlay {
	opacity: 1;
}

.image-info {
	color: white;
	transform: translateY(10px);
	transition: transform 0.3s ease;
}

.image-wrapper:hover .image-info {
	transform: translateY(0);
}

.image-name {
	font-weight: 600;
	font-size: 0.875rem;
	margin-bottom: 0.25rem;
	overflow: hidden;
	text-overflow: ellipsis;
	white-space: nowrap;
}

.image-meta {
	font-size: 0.75rem;
	opacity: 0.9;
}

@keyframes fadeIn {
	from {
		opacity: 0;
	}
	to {
		opacity: 1;
	}
}

@keyframes slideUp {
	from {
		opacity: 0;
		transform: translateY(30px);
	}
	to {
		opacity: 1;
		transform: translateY(0);
	}
}
</style>
