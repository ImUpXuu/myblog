---
import type { GetStaticPaths } from "astro";
import Pagination from "../components/control/Pagination.astro";
import PostPage from "../components/PostPage.astro";
import BannerTitle from "../components/BannerTitle.astro";
import { PAGE_SIZE } from "../constants/constants";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { getSortedPosts } from "../utils/content-utils";
import { siteConfig, profileConfig } from "../config";

export const getStaticPaths = (async ({ paginate }) => {
	const allBlogPosts = await getSortedPosts();
	return paginate(allBlogPosts, { pageSize: PAGE_SIZE });
}) satisfies GetStaticPaths;
// https://github.com/withastro/astro/issues/6507#issuecomment-1489916992

const { page } = Astro.props;

const len = page.data.length;

const isFirstPage = page.url.prev === undefined;

const jsonLd = isFirstPage ? {
	"@context": "https://schema.org",
	"@type": "WebSite",
	"@id": `${Astro.site}`,
	name: siteConfig.title,
	description: siteConfig.subtitle,
	url: Astro.site,
	publisher: {
		"@type": "Person",
		name: profileConfig.name,
	},
	author: {
		"@type": "Person",
		name: profileConfig.name,
	},
	inLanguage: siteConfig.lang.replace("_", "-"),
} : null;
---

<MainGridLayout>
    <BannerTitle slot="banner-title"></BannerTitle>
    {jsonLd && <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>}
    <PostPage page={page}></PostPage>
    <Pagination class="mx-auto onload-animation" page={page} style={`animation-delay: calc(var(--content-delay) + ${(len)*50}ms)`}></Pagination>
</MainGridLayout>

<script>
// 批量获取首页文章的访问量和点赞数
function fetchHomepageStats() {
    const apiUrl = 'https://umami-proxy.upxuu.workers.dev';
    const postCards = document.querySelectorAll('[data-post-url]');

    // 收集所有文章 URL
    const urls = Array.from(postCards)
        .map(card => card.getAttribute('data-post-url'))
        .filter(url => url !== null);

    if (urls.length === 0) return;

    // 构建查询参数
    const query = urls.map(url => `url=${encodeURIComponent(url)}`).join('&');

    // 使用 Cloudflare Worker 批量获取统计
    fetch(`${apiUrl}/api/homepage-stats?${query}`)
        .then(res => res.ok ? res.json() : null)
        .then(data => {
            if (!data || !data.stats) return;
            
            // 更新每个文章卡片的统计
            data.stats.forEach((stat, index) => {
                const card = postCards[index];
                if (!card) return;
                
                const viewsEl = card.querySelector('.post-views');
                const likesEl = card.querySelector('.post-likes');
                if (viewsEl) viewsEl.textContent = stat.views || 0;
                if (likesEl) likesEl.textContent = stat.likes || 0;
            });
        })
        .catch(() => {});
}

// 等待 DOM 加载完成后获取统计数据
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', fetchHomepageStats);
} else {
    fetchHomepageStats();
}
</script>