# Redirects from old WordPress URLs to new Fuwari structure

# IMPORTANT: Redirects are processed in order. 
# Existing files shadow redirects unless forced with '!'
# We need to exclude sitemap and special paths first

# Exclude sitemap files (must come before the catch-all redirect)
/sitemap-index.xml  /sitemap-index.xml  200
/posts/sitemap-index.xml  /posts/sitemap-index.xml  200
/sitemap.xml  /sitemap.xml  200
/posts/sitemap.xml  /posts/sitemap.xml  200

# Exclude static assets
/assets/*  /assets/:splat  200
/images/*  /images/:splat  200
/fonts/*  /fonts/:splat  200

# Exclude static pages that exist at root
/about  /about  200
/archive  /archive  200
/rss.xml  /rss.xml  200

# Redirect root-level article URLs to /posts/
# This catches old WordPress URLs like /my-post and redirects to /posts/my-post
/*  /posts/:splat  301
